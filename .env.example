# Copy this file to .env and fill in your real credentials.
# .env is gitignored and never leaves your machine.

ESTUDENT_NETID=your_netid
ESTUDENT_PASSWORD=your_password

# eStudent entry URL (adjust if the portal moves)
ESTUDENT_BASE_URL=https://www.polyu.edu.hk/student

# Set to 1 to run the browser in headful (visible) mode for debugging
ESTUDENT_HEADFUL=0
